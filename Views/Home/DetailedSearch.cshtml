@model Zubair_Zunairah_HW3.Models.ViewModels.SearchViewModel

@{
    ViewData["Title"] = "Detailed Search";
}

<h2>Detailed Search</h2>
<hr />

<form asp-action="DisplaySearchResults" asp-controller="Home" method="get">

    <div class="form-group">
        <label asp-for="SearchString" class="control-label"></label>
        <input asp-for="SearchString" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="SelectedGenreId" class="control-label"></label>
        <select asp-for="SelectedGenreId" asp-items="Model.GenreList" class="form-control">
            <option value="">All Genres</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="SelectedFormat" class="control-label"></label>
        <select asp-for="SelectedFormat" asp-items="Model.FormatList" class="form-control">
            <option value="">All Formats</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="Price" class="control-label"></label>
        <input asp-for="Price" class="form-control" />
    </div>

    <div class="form-group">
        <div class="form-check">
            <input class="form-check-input" type="radio" asp-for="SearchGreaterThan" value="true" checked />
            <label class="form-check-label">Greater Than (or equal)</label>
        </div>

        <div class="form-check">
            <input class="form-check-input" type="radio" asp-for="SearchGreaterThan" value="false" />
            <label class="form-check-label">Less Than (or equal)</label>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="ReleasedAfter" class="control-label"></label>
        <input asp-for="ReleasedAfter" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>

</form>